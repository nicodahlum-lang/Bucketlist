# Vercel Postgres Environment Variables
# You can find these in your Vercel Dashboard -> Storage -> Postgres

POSTGRES_URL="postgres://default:password@ep-xxx.us-east-1.aws.neon.tech/verceldb?sslmode=require"
POSTGRES_PRISMA_URL="postgres://default:password@ep-xxx.us-east-1.aws.neon.tech/verceldb?sslmode=require&pgbouncer=true"
POSTGRES_URL_NON_POOLING="postgres://default:password@ep-xxx.us-east-1.aws.neon.tech/verceldb?sslmode=require"

# Database Setup SQL (Run this in Vercel Postgres Console):
# CREATE TABLE lists (id UUID PRIMARY KEY DEFAULT gen_random_uuid(), name TEXT NOT NULL, created_at TIMESTAMP DEFAULT NOW());
# CREATE TABLE items (id UUID PRIMARY KEY DEFAULT gen_random_uuid(), list_id UUID REFERENCES lists(id), category TEXT, text TEXT NOT NULL, completed BOOLEAN DEFAULT false, created_at TIMESTAMP DEFAULT NOW());
